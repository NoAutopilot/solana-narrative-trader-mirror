# ── Solana Narrative Trader — Environment Variables ─────────────────────────
# Copy this file to /root/solana_trader/trader_env.conf and fill in real values.
# NEVER commit the real file. It is listed in .gitignore.

# ── Required for live trading ─────────────────────────────────────────────────
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
WALLET_PRIVATE_KEY=YOUR_BASE58_WALLET_PRIVATE_KEY
WALLET_PUBKEY=YOUR_WALLET_PUBLIC_KEY
JUPITER_API_KEY=YOUR_JUPITER_API_KEY

# ── Optional: PumpPortal Lightning API ───────────────────────────────────────
PUMPPORTAL_API_KEY=YOUR_PUMPPORTAL_API_KEY

# ── Live Trading Config ───────────────────────────────────────────────────────
# Set LIVE_TRADING_ENABLED=true only after preflight checks pass.
LIVE_TRADING_ENABLED=false
LIVE_ENABLED=false
LIVE_TRADE_SIZE_SOL=0.02
LIVE_SLIPPAGE_PCT=20
LIVE_PRIORITY_FEE=0.0001
LIVE_CONVICTION_FILTER=proactive_only
LIVE_BUY_POOL=smart

# ── Safety Limits ─────────────────────────────────────────────────────────────
MAX_LIVE_TRADES_PER_HOUR=100
MAX_TOTAL_LIVE_TRADES=999999
MAX_CONCURRENT_LIVE_TRADES=15
MAX_SOL_PER_TRADE=0.05
MIN_WALLET_BALANCE_SOL=0.01

# ── Experiment: auto-halt new buys after N seconds (0=disabled) ──────────────
LIVE_EXPERIMENT_DURATION_SEC=14400
